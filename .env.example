# Copy this file to .env for local experiments.
# Never commit real API keys, tokens, cookies, or service account JSON files.

# Optional: Firecrawl API key for integrations/examples/firecrawl_fetch.py
FIRECRAWL_API_KEY=

# Optional: Google service account JSON path for integrations/examples/google_sheets_append.py
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json

# Local n8n settings for docker-compose.yml
N8N_HOST=localhost
N8N_PORT=5678
N8N_PROTOCOL=http
N8N_BASIC_AUTH_ACTIVE=true
N8N_BASIC_AUTH_USER=trendpilot
# Required before running docker compose. Use a local password you generate yourself.
N8N_BASIC_AUTH_PASSWORD=
GENERIC_TIMEZONE=UTC
